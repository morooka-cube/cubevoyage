---
import BaseLayout from '../layouts/BaseLayout.astro';
import teapotImgAsset from '../assets/2017/04/418-Im-a-teapot-1.jpg';

// ▼ イースターエッグ：このルートのみ SSR（オンデマンド）でレンダリングし、
//    Cloudflare 上で本物の HTTP 418 "I'm a teapot" ステータスを返す。
export const prerender = false;

// HTTPステータスを 418 に設定
Astro.response.status = 418;
Astro.response.statusText = "I'm a teapot";

const teapotImg = teapotImgAsset.src;
---

<BaseLayout title="418 I'm a teapot" path="/teapot/" ogImage={teapotImg} noindex={true}>
  <div class="layout">
    <main id="main">
      <div class="teapot" style="text-align:center; padding:24px 0 48px;">
        <p style="font-size:clamp(3.5rem,8vw,6rem); font-weight:900; color:var(--brand); margin:0; line-height:1;">
          418
        </p>
        <h1 style="margin:.3em 0 1em; font-size:clamp(1.4rem,4vw,2rem);">
          I'm a teapot 🫖
        </h1>
        <img
          src={teapotImg}
          alt="418 I'm a teapot"
          style="max-width:560px; width:100%; border-radius:12px; box-shadow:var(--shadow);"
        />
        <p style="margin-top:1.6em; color:var(--text-soft); max-width:560px; margin-left:auto; margin-right:auto;">
          このサーバーはティーポットです。コーヒーを淹れることを拒否します。<br />
          （<a href="https://datatracker.ietf.org/doc/html/rfc2324" target="_blank" rel="noopener">RFC 2324 — Hyper Text Coffee Pot Control Protocol</a> より）
        </p>
        <p style="margin-top:2em;">
          <a href="/" class="card" style="display:inline-block; max-width:none;">ホームに戻る →</a>
        </p>
      </div>
    </main>
  </div>
</BaseLayout>
