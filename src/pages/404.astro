---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません" path="/404/" noindex={true}>
  <div class="layout">
    <main id="main">
      <div style="text-align:center; padding:48px 0;">
        <p style="font-size:clamp(3rem,8vw,5rem); font-weight:900; color:var(--brand); margin:0; line-height:1;">
          404
        </p>
        <h1 style="margin:.4em 0 1em;">ページが見つかりません</h1>
        <p style="color:var(--text-soft);">
          お探しのページは移動または削除された可能性があります。
        </p>
        <p style="margin-top:1.5em;">
          <a class="card" style="display:inline-block; max-width:none;" href="/">ホームに戻る →</a>
        </p>
      </div>
    </main>
  </div>
</BaseLayout>
