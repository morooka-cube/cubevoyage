---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content as HomeContent } from '../home.md';
import { SITE } from '../lib/site';
import { primaryNav, footerNav } from '../lib/pages';
import brandBanner from '../assets/brand-banner.jpg';

// 主要セクションのカード（子ページ数つき）
const sectionCards = primaryNav.map((n) => ({
  path: n.path,
  title: n.title,
  count: n.children.length,
}));
---

<BaseLayout title={SITE.title} path="/" ogImage={brandBanner.src}>
  <div class="layout">
    <main id="main">
      <section class="hero">
        <img
          class="hero-banner"
          src={brandBanner.src}
          alt="Cube Voyage — It's time to start eternal travel."
          width="960"
          height="397"
        />
        <h1 class="sr-only">Cube Voyage</h1>
        <p class="hero-desc">{SITE.description}</p>
      </section>

      <div class="content"><HomeContent /></div>

      <h2 style="margin-top:2em;">コンテンツ</h2>
      <div class="card-grid">
        {
          sectionCards.map((c) => (
            <a class="card" href={c.path}>
              <h3>{c.title}</h3>
              {c.count > 0 && <p class="count">{c.count} カテゴリ →</p>}
            </a>
          ))
        }
      </div>

      <h2>サイト案内</h2>
      <div class="child-list">
        {footerNav.map((n) => <a href={n.path}>{n.title}</a>)}
      </div>
    </main>
  </div>
</BaseLayout>
